generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// A nossa tabela de cartelas no banco de dados
// Modelo da Cartela de Bingo
model BingoCard {
  id           String   @id @default(cuid())
  serialNumber String   @unique // O número que identifica a cartela física
  numbers      Int[]    // Array de números (o 'LIVRE' vira 0 aqui)
  color        String   @default("jornal") // Cor da rodada (jornal, verde, rosa, etc.)
  
  // Relação com o Usuário do Supabase
  userId       String   // Aqui guardamos o UUID que vem do seu Login
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
